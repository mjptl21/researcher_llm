# Copy to .env and adjust values for local development.
# cp .env.example .env

# ── Runner mode ───────────────────────────────────────────────────────────────
# Which backend executes research runs (checked in order):
#   1. DUMMY_MODE=true  → dummy_runner.py (no LLM; replay canned SSE events)
#   2. ZEN_MODE=true    → zen_runner.py (real LLM via OpenCode Zen gateway)
#   3. both false       → agent_runner.py (Claude Agent SDK — placeholder)
#
# DUMMY_MODE takes precedence when true. For real LLM runs, set DUMMY_MODE=false
# and ZEN_MODE=true.

DUMMY_MODE=false

# Use zen_runner (OpenAI-compatible gateway). Requires ZEN_API_KEY when enabled.
ZEN_MODE=true

# Fixture replayed by dummy_runner when DUMMY_MODE=true.
# Options: full | ask_user | error (see dummy_runner.py)
DUMMY_FIXTURE=full

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origin allowed for browser requests from the Vite dev server.
FRONTEND_ORIGIN=http://localhost:5173

# ── OpenCode Zen (required when ZEN_MODE=true) ────────────────────────────────
# API key from https://opencode.ai — zen_runner raises if missing at runtime.
ZEN_API_KEY=

# OpenAI-compatible base URL. The SDK appends /chat/completions automatically.
# ZEN_BASE_URL=https://opencode.ai/zen/v1

# Model slug supported by Zen, e.g. deepseek-v4-flash-free, claude-sonnet-4-5.
ZEN_MODEL=deepseek-v4-flash-free

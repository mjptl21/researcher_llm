# Copy to .env and adjust values for local development.
# cp .env.example .env

# ── Backend ───────────────────────────────────────────────────────────────────
# Agents run on the OpenHands Agent SDK harness; the agent definitions ship as
# an SDK plugin in backend/deep-analyst-plugin/ (loaded via Plugin.load()).
# Models are served by the OpenCode Zen gateway, so ZEN_API_KEY is required.

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origin allowed for browser requests from the Vite dev server.
FRONTEND_ORIGIN=http://localhost:5173

# ── OpenCode Zen (model gateway — required) ──────────────────────────────────
# API key from https://opencode.ai — the runner raises if missing at runtime.
ZEN_API_KEY=

# OpenAI-compatible base URL. /chat/completions is appended automatically.
# ZEN_BASE_URL=https://opencode.ai/zen/v1

# Model slug supported by Zen, e.g. deepseek-v4-flash-free, claude-sonnet-4-5.
ZEN_MODEL=deepseek-v4-flash-free
